{
  "name": "eslint-plugin-cypress-silent-pass",
  "version": "0.1.1",
  "description": "ESLint rule that flags Cypress chai assertions that always pass — cy.get() yields a chainable object that always exists, so expect(cy.get('.x')).to.exist / .to.be.ok / .not.to.be.null can never fail. Auto-fixable.",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "cypress",
    "testing",
    "assertions",
    "silent-pass"
  ],
  "license": "Apache-2.0",
  "author": "voidmatcha (https://github.com/voidmatcha)",
  "homepage": "https://github.com/voidmatcha/eslint-plugin-cypress-silent-pass#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voidmatcha/eslint-plugin-cypress-silent-pass.git"
  },
  "bugs": {
    "url": "https://github.com/voidmatcha/eslint-plugin-cypress-silent-pass/issues"
  },
  "type": "commonjs",
  "main": "lib/index.js",
  "exports": "./lib/index.js",
  "files": [
    "lib",
    "docs",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node tests/no-silent-pass.test.js",
    "prepublishOnly": "node tests/no-silent-pass.test.js"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  }
}
